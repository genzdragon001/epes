# EPES System Environment Configuration
# Copy this file to .env and update with your actual credentials

# Database Configuration
DB_HOST=localhost
DB_NAME=epes_db
DB_USER=root
DB_PASS=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@epes.edu.ph
SMTP_FROM_NAME=EPES System

# System Configuration
SYSTEM_URL=http://localhost/epes
ENCRYPTION_KEY=epes-secret-key-2025

# Session Configuration
SESSION_TIMEOUT=900

# Security
CSRF_SECRET=epes-csrf-secret-2025
