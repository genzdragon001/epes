# EPES System Environment Configuration
# DO NOT commit this file to version control with sensitive data

# Database Configuration
DB_HOST=localhost
DB_NAME=epes_db
DB_USER=root
DB_PASS=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@epes.edu.ph
SMTP_FROM_NAME=EPES System

# System Configuration
SYSTEM_URL=http://localhost/epes
ENCRYPTION_KEY=your-secret-encryption-key-here

# Session Configuration
SESSION_TIMEOUT=900

# Security
CSRF_SECRET=your-csrf-secret-key-here
